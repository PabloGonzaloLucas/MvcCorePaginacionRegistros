@model IEnumerable<MvcCorePaginacionRegistros.Models.Empleado>

@{
    int numPagina = 1;
    int numRegistros = (int)ViewBag.REGISTROS;
}
@{
    ViewData["Title"] = "PaginarGrupoEmpleados";
}

<h1>PaginarGrupoEmpleados</h1>

<ul class="list-group list-group-horizontal">
    @for(int i = 1; i<= numRegistros; i += 3)
    {
        <li class="list-group-item">
            <a asp-controller="Paginacion" asp-action="PaginarGrupoEmpleados"
            asp-route-posicion="@i">@numPagina</a>
        </li>
        numPagina += 1;
    }
</ul>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Apellido)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Oficio)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Salario)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.IdDepartamento)
            </th>
            
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Apellido)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Oficio)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Salario)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.IdDepartamento)
            </td>
        
        </tr>
}
    </tbody>
</table>
